# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Stellar Testnet Configuration (Migrated from Celo)
# Native Currency: XLM (instead of CELO)
# Admin Public Address (G...)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_ADMIN_PUBLIC_ADDRESS=
# IMPORTANT: Store the admin secret securely - starts with 'SA' for Stellar Testnet
STELLAR_ADMIN_SECRET=
# Backward-compatible key read by current backend runtime
ADMIN_WALLET_PRIVATE_KEY=
# Soroban RPC (for smart contracts)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443

# Soroban Contract IDs (populate after deployment)
INVX_TOKEN_CONTRACT_ID=
BUSINESS_TOKEN_CONTRACT_ID=
ESCROW_CONTRACT_ID=
ESCROW_CONTRACT_ADDRESS=
DIVIDEND_CONTRACT_ID=
DOCUMENT_REGISTRY_ID=
GOVERNANCE_CONTRACT_ID=
REWARD_DISTRIBUTOR_ID=

# Google Gemini AI
GEMINI_API_KEY=

# Pinata IPFS
PINATA_JWT=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Frontend URL (for CORS) — production Vercel deployment
FRONTEND_URL=https://fino-srijon.vercel.app
